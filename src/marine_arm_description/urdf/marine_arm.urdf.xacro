<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="marine_arm">

    <xacro:property name="arm_mass" value="50.0" /> <xacro:property name="base_radius" value="0.4" />
    <xacro:property name="base_length" value="0.5" />
    <xacro:property name="link1_length" value="2.0" />
    <xacro:property name="link1_radius" value="0.15" />
    <xacro:property name="link2_length" value="2.0" />
    <xacro:property name="link2_radius" value="0.12" />

    <xacro:macro name="cylinder_inertia" params="m r h">
        <inertial>
            <mass value="${m}"/>
            <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0" 
                     iyy="${m*(3*r*r+h*h)/12}" iyz="0" 
                     izz="${m*r*r/2}"/>
        </inertial>
    </xacro:macro>

    <link name="world"/>
    <joint name="world_fixed" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
    </joint>

    <link name="base_link">
        <visual>
            <geometry><cylinder radius="${base_radius}" length="${base_length}"/></geometry>
            <material name="blue"><color rgba="0.1 0.3 0.8 1.0"/></material>
            <origin xyz="0 0 ${base_length/2}" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry><cylinder radius="${base_radius}" length="${base_length}"/></geometry>
            <origin xyz="0 0 ${base_length/2}" rpy="0 0 0"/>
        </collision>
        <xacro:cylinder_inertia m="100.0" r="${base_radius}" h="${base_length}"/>
    </link>

    <joint name="base_yaw_joint" type="revolute">
        <parent link="base_link"/>
        <child link="shoulder_link"/>
        <origin xyz="0 0 ${base_length}" rpy="0 0 0"/>
        <axis xyz="0 0 1"/> <limit lower="-3.14" upper="3.14" effort="5000.0" velocity="1.0"/>
    </joint>

    <link name="shoulder_link">
        <visual>
            <geometry><box size="0.3 0.3 0.3"/></geometry>
            <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
        </visual>
        <collision><geometry><box size="0.3 0.3 0.3"/></geometry></collision>
        <inertial>
            <mass value="20.0"/>
            <inertia ixx="0.3" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.3"/>
        </inertial>
    </link>

    <joint name="shoulder_pitch_joint" type="revolute">
        <parent link="shoulder_link"/>
        <child link="upper_arm_link"/>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <axis xyz="0 1 0"/> <limit lower="-1.57" upper="1.57" effort="8000.0" velocity="1.0"/>
    </joint>

    <link name="upper_arm_link">
        <visual>
            <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
            <geometry><cylinder radius="${link1_radius}" length="${link1_length}"/></geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
            <geometry><cylinder radius="${link1_radius}" length="${link1_length}"/></geometry>
        </collision>
        <xacro:cylinder_inertia m="${arm_mass}" r="${link1_radius}" h="${link1_length}"/>
    </link>

    <joint name="elbow_pitch_joint" type="revolute">
        <parent link="upper_arm_link"/>
        <child link="forearm_link"/>
        <origin xyz="0 0 ${link1_length}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/> <limit lower="-2.5" upper="2.5" effort="6000.0" velocity="1.5"/>
    </joint>

    <link name="forearm_link">
        <visual>
            <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
            <geometry><cylinder radius="${link2_radius}" length="${link2_length}"/></geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
            <geometry><cylinder radius="${link2_radius}" length="${link2_length}"/></geometry>
        </collision>
        <xacro:cylinder_inertia m="30.0" r="${link2_radius}" h="${link2_length}"/>
    </link>

    <joint name="wrist_pitch_joint" type="revolute">
        <parent link="forearm_link"/>
        <child link="end_effector_link"/>
        <origin xyz="0 0 ${link2_length}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="2000.0" velocity="2.0"/>
    </joint>

    <link name="end_effector_link">
        <visual>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry><box size="0.4 0.4 0.1"/></geometry> <material name="red"><color rgba="0.8 0.1 0.1 1.0"/></material>
        </visual>
        <collision>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry><box size="0.4 0.4 0.1"/></geometry>
        </collision>
        <inertial>
            <mass value="5.0"/>
            <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
        </inertial>
    </link>

    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>mock_components/GazeboSystem</plugin>
        </hardware>

        <xacro:macro name="configure_joint" params="joint_name">
            <joint name="${joint_name}">
                <command_interface name="position">
                    <param name="min">-3.14</param>
                    <param name="max">3.14</param>
                </command_interface>
                <state_interface name="position"/>
                <state_interface name="velocity"/>
            </joint>
        </xacro:macro>

        <xacro:configure_joint joint_name="base_yaw_joint"/>
        <xacro:configure_joint joint_name="shoulder_pitch_joint"/>
        <xacro:configure_joint joint_name="elbow_pitch_joint"/>
        <xacro:configure_joint joint_name="wrist_pitch_joint"/>
    </ros2_control>

    <gazebo>
        <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
            <parameters>$(find marine_arm_description)/config/ros2_controllers.yaml</parameters>
        </plugin>
    </gazebo>

</robot>