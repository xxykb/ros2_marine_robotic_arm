<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robo_arm2">

  <!-- Include Gazebo simulation xacro -->
  <xacro:include filename="$(find robo_arm2_description)/urdf/robo_arm2.gazebo.xacro" />

  <!-- Constants -->
  <xacro:property name="base_radius" value="0.10" />
  <xacro:property name="base_height" value="0.05" />
  <xacro:property name="link1_radius" value="0.04" />
  <xacro:property name="link1_length" value="0.05" />
  <xacro:property name="link2_radius" value="0.03" />
  <xacro:property name="link2_length" value="0.30" />
  <xacro:property name="link3_radius" value="0.025" />
  <xacro:property name="link3_length" value="0.25" />
  <xacro:property name="ee_radius" value="0.02" />
  <xacro:property name="pillar_radius" value="0.05" />
  <xacro:property name="pillar_height" value="0.05" />

  <!-- Inertia macro for cylinders (origin at center of mass) -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}" />
      <origin xyz="0 0 ${h/2}" rpy="0 0 0" />
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*(r*r)/2}" />
    </inertial>
  </xacro:macro>

  <!-- Inertia macro for spheres -->
  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="${2*m*r*r/5}" ixy="0" ixz="0"
               iyy="${2*m*r*r/5}" iyz="0"
               izz="${2*m*r*r/5}" />
    </inertial>
  </xacro:macro>

  <!-- Colors -->
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0" />
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0" />
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0" />
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0" />
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0" />
  </material>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}" />
      </geometry>
      <material name="dark_grey" />
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}" />
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1.0" r="${base_radius}" h="${base_height}" />
  </link>

  <!-- ==================== PILLAR (part of base) ==================== -->
  <link name="pillar_link">
    <visual>
      <origin xyz="0 0 ${pillar_height/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${pillar_radius}" length="${pillar_height}" />
      </geometry>
      <material name="dark_grey" />
    </visual>
    <collision>
      <origin xyz="0 0 ${pillar_height/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${pillar_radius}" length="${pillar_height}" />
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.5" r="${pillar_radius}" h="${pillar_height}" />
  </link>

  <joint name="base_to_pillar" type="fixed">
    <parent link="base_link" />
    <child link="pillar_link" />
    <origin xyz="0 0 ${base_height}" rpy="0 0 0" />
  </joint>

  <!-- ==================== JOINT1: Base Rotation (Z-axis) ==================== -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${link1_radius}" length="${link1_length}" />
      </geometry>
      <material name="blue" />
    </visual>
    <collision>
      <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${link1_radius}" length="${link1_length}" />
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.3" r="${link1_radius}" h="${link1_length}" />
  </link>

  <joint name="joint1" type="revolute">
    <parent link="pillar_link" />
    <child link="link1" />
    <origin xyz="0 0 ${pillar_height}" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14159" upper="3.14159" effort="50.0" velocity="1.0" />
    <dynamics damping="0.01" friction="0.01" />
  </joint>

  <!-- ==================== JOINT2: Elbow Pitch (Y-axis) ==================== -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${link2_radius}" length="${link2_length}" />
      </geometry>
      <material name="orange" />
    </visual>
    <collision>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${link2_radius}" length="${link2_length}" />
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.2" r="${link2_radius}" h="${link2_length}" />
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1" />
    <child link="link2" />
    <origin xyz="0 0 ${link1_length}" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="-1.5708" upper="3.14159" effort="30.0" velocity="1.0" />
    <dynamics damping="0.01" friction="0.01" />
  </joint>

  <!-- ==================== JOINT3: Wrist Pitch (Y-axis) ==================== -->
  <link name="link3">
    <visual>
      <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${link3_radius}" length="${link3_length}" />
      </geometry>
      <material name="green" />
    </visual>
    <collision>
      <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="${link3_radius}" length="${link3_length}" />
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.1" r="${link3_radius}" h="${link3_length}" />
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2" />
    <child link="link3" />
    <origin xyz="0 0 ${link2_length}" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="-3.14159" upper="3.14159" effort="20.0" velocity="1.0" />
    <dynamics damping="0.01" friction="0.01" />
  </joint>

  <!-- ==================== END EFFECTOR ==================== -->
  <link name="end_effector">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="${ee_radius}" />
      </geometry>
      <material name="red" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="${ee_radius}" />
      </geometry>
    </collision>
    <xacro:sphere_inertia m="0.02" r="${ee_radius}" />
  </link>

  <joint name="ee_joint" type="fixed">
    <parent link="link3" />
    <child link="end_effector" />
    <origin xyz="0 0 ${link3_length}" rpy="0 0 0" />
  </joint>

  <!-- ==================== ros2_control ==================== -->
  <ros2_control name="MockSystem" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
      <param name="fake_sensor_command_interfaces">true</param>
      <param name="state_following_offset">0.0</param>
    </hardware>
    <joint name="joint1">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
    <joint name="joint2">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
    <joint name="joint3">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
  </ros2_control>

  <!-- Gazebo simulation plugin -->
  <xacro:robo_arm2_gazebo />

</robot>
